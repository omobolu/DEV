PORT=3001
NODE_ENV=development
# DEV ONLY — Production requires a randomly generated high-entropy secret (min 32 chars).
# Generate with: openssl rand -base64 48
JWT_SIGNING_SECRET=change-me-in-production
DATABASE_URL=postgresql://idvize:idvize_dev_2026@localhost:5432/idvize

# Data Initialization Strategy
# SEED_MODE controls what data is loaded on startup:
#   production  (default) — NO demo data. System starts empty. For real SaaS customers.
#   demo                  — Seeds ACME + Globex demo tenants with full portfolios.
#   development           — Same as demo; allows flexible seeding + data reset.
SEED_MODE=development

# Optional — AI features degrade gracefully without this
# ANTHROPIC_API_KEY=sk-ant-...

# Optional — Platform adapters fall back to mock mode
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# SAILPOINT_BASE_URL=
# SAILPOINT_CLIENT_ID=
# SAILPOINT_CLIENT_SECRET=
# CYBERARK_BASE_URL=
# CYBERARK_USERNAME=
# CYBERARK_PASSWORD=
# OKTA_DOMAIN=
